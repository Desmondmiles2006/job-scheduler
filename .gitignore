# ── Dependencies ────────────────────────────────────────────
# Hoisted to root by npm workspaces, but ignore everywhere just
# in case a package ever gets its own local install.
node_modules/
**/node_modules/

# ── Build output ────────────────────────────────────────────
dist/
dist-ssr/
build/
**/dist/
**/build/
*.tsbuildinfo

# ── Environment files ───────────────────────────────────────
# Real secrets/local connection strings never get committed;
# .env.example templates are the only ones tracked.
.env
.env.*
!.env.example

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test / coverage output ──────────────────────────────────
coverage/
.nyc_output/

# ── Vite / bundler caches ───────────────────────────────────
.vite/
node_modules/.vite/
.turbo/
.cache/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Postgres (only relevant if you ever bind-mount instead of
#    using the named Docker volume in docker-compose.yml) ────
pgdata/
*.pgdump

# ── Misc ─────────────────────────────────────────────────────
*.local
.DS_Store

# ── Claude Code local settings (machine-specific permissions cache) ──
.claude/
